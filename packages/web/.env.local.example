# Agent Orchestrator — Web Dashboard Local Dev Environment
#
# Copy to .env.local and customize. Next.js auto-loads .env.local in dev.
# For production, see .env.production.example (shipped in PR #103 for #79).
#
# IMPORTANT: never commit real secrets to .env.local. This file is a
# template — fill in values locally and keep .env.local in .gitignore.

# Terminal server ports (14800 range chosen to avoid conflicts with dev tools)
TERMINAL_PORT=14800                 # ttyd (iframe) terminal server
DIRECT_TERMINAL_PORT=14801          # Direct WebSocket terminal server with XDA support

# Public environment variables (exposed to browser bundle — safe defaults)
NEXT_PUBLIC_TERMINAL_PORT=14800
NEXT_PUBLIC_DIRECT_TERMINAL_PORT=14801
# Optional: override the terminal WebSocket path (defaults to /ws)
# NEXT_PUBLIC_TERMINAL_WS_PATH=/ws

# SCM webhook secret — must match the secret configured in your SCM
# provider's webhook settings. Referenced by agent-orchestrator.yaml as
# `secretEnvVar: GITHUB_WEBHOOK_SECRET`. Leave empty to disable
# signature verification in dev (NOT recommended for prod).
GITHUB_WEBHOOK_SECRET=

# Optional: Sentry DSN for crash reporting. If unset, falls back to the
# local ~/.agent-orchestrator/error.log file.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=          # client-side Sentry (must be NEXT_PUBLIC_ for browser)
# SENTRY_ENVIRONMENT=production   # dev/staging/prod
# SENTRY_TRACES_SAMPLE_RATE=0.1   # performance sampling (0-1)

# Optional: override the config path (e.g. to use a prod template in dev)
# AO_CONFIG_PATH=agent-orchestrator.prod.yaml
