# Agent Orchestrator — Production Environment Variables (Next.js dashboard)
#
# Copy to .env.production and customize. Next.js loads this automatically when
# NODE_ENV=production. See issue #79.
#
# IMPORTANT: never commit real secrets to .env.production. Use this example as
# a template and fill in values via your deployment platform's secret manager
# (Docker secrets, Kubernetes secrets, AWS SSM, etc.).

# Terminal server ports (14800 range chosen to avoid conflicts with dev tools)
TERMINAL_PORT=14800
DIRECT_TERMINAL_PORT=14801

# Public environment variables (exposed to the browser bundle)
NEXT_PUBLIC_TERMINAL_PORT=14800
NEXT_PUBLIC_DIRECT_TERMINAL_PORT=14801

# SCM webhook secret — must match the secret configured in your SCM provider's
# webhook settings. Referenced by agent-orchestrator.prod.yaml as
# `secretEnvVar: GITHUB_WEBHOOK_SECRET`.
GITHUB_WEBHOOK_SECRET=

# Optional: Sentry DSN for production crash reporting. If unset, the dashboard
# falls back to the local ~/.agent-orchestrator/error.log file (see logFatal).
# SENTRY_DSN=

# Optional: override the config path to point at the production config template.
# AO_CONFIG_PATH=/opt/ao/agent-orchestrator.prod.yaml
