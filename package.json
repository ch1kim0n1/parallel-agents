{
  "name": "agentmesh",
  "version": "0.1.0",
  "private": true,
  "description": "AgentMesh: Orchestrate parallel AI coding agents across any runtime, any repo, any issue tracker",
  "license": "MIT",
  "engines": {
    "node": ">=20.18.3"
  },
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @aoagents/ao-core build && pnpm --filter @aoagents/agentmesh-core build && pnpm --filter @aoagents/agentmesh-adapters build && pnpm -r --filter \"./packages/plugins/**\" build && pnpm --filter @aoagents/ao-cli build && pnpm --filter @aoagents/ao-web build && pnpm --filter @aoagents/agentmesh-cli build",
    "dev": "pnpm --filter @aoagents/ao-web dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm --filter @aoagents/ao-core build && pnpm -r --filter \"!@aoagents/ao-integration-tests\" typecheck",
    "test": "pnpm -r --filter \"!@aoagents/ao-integration-tests\" --if-present test",
    "test:integration": "pnpm --filter @aoagents/ao-integration-tests test:integration",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r build && changeset publish",
    "prepare": "husky",
    "postinstall": "node scripts/rebuild-node-pty.js"
  },
  "devDependencies": {
    "@aoagents/ao": "workspace:*",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^15.5.15",
    "@types/node": "^25.2.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "istanbul-lib-coverage": "^3.2.2",
    "prettier": "^3.9.3",
    "typescript-eslint": "^8.62.0"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.15.0",
      "axios>follow-redirects": "^1.16.0",
      "external-editor>tmp": "0.2.4",
      "ws": "^8.21.0",
      "postcss": "^8.4.49"
    }
  }
}
